# Supabase — get from: supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# n8n automation engine
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/bigfella-inbound
N8N_WEBHOOK_SECRET=your-shared-secret-here